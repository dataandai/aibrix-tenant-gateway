# DANGER ZONE full-stack AWS path.
# Copy to .aws-danger.env or export these variables explicitly.
#
# This path can create paid EKS, GPU EC2, EBS, ECR, S3, Cognito, and LoadBalancer resources.
# The consent flag is intentionally NOT enabled here. Set it manually after reading docs/11-aws-full-stack-danger-zone.md.
#
#   export I_UNDERSTAND_AWS_GPU_COST_AND_QUOTAS=yes
#
I_UNDERSTAND_AWS_GPU_COST_AND_QUOTAS=

AWS_REGION=eu-west-1
CLUSTER_NAME=aibrix-gateway-full-stack
ECR_REPOSITORY=aibrix-multitenant-llm-gateway
IMAGE_TAG=aws-full-stack

# GPU capacity. g5.2xlarge has one NVIDIA A10G GPU. Change if your account has other quota.
CPU_INSTANCE_TYPE=t3.large
GPU_INSTANCE_TYPE=g5.2xlarge
GPU_DESIRED_CAPACITY=1
GPU_MAX_SIZE=2
GPU_VOLUME_SIZE_GB=300

# Safer default: put nodes in private subnets. This requires NAT or equivalent egress for image/model pulls.
# Set AWS_DANGER_PRIVATE_NETWORKING=false only for throwaway experiments after reading the warning docs.
AWS_DANGER_PRIVATE_NETWORKING=true

# AIBrix/vLLM. Defaults follow the AIBrix quickstart shape for a single A10G-style demo.
AIBRIX_VERSION=v0.7.0
AIBRIX_MANIFEST_BASE_URL=https://github.com/vllm-project/aibrix/releases/download
ENVOY_GATEWAY_HELM_VERSION=v1.2.8
NVIDIA_DEVICE_PLUGIN_VERSION=v0.16.2
VLLM_IMAGE=vllm/vllm-openai:v0.11.0
MODEL_ID=deepseek-ai/DeepSeek-R1-Distill-Llama-8B
SERVED_MODEL_NAME=deepseek-r1-distill-llama-8b
MAX_MODEL_LEN=12288
GPU_MEMORY_UTILIZATION=0.90
AIBRIX_MODEL_NAMESPACE=default
MODEL_ROLLOUT_TIMEOUT=1800s

# Optional Hugging Face token for gated/private models.
# The deploy script stores it as a Kubernetes Secret, not a plain Pod env literal.
# HF_TOKEN=hf_...

# The full-stack gateway defaults to an internal AWS NLB.
# Use internet-facing only for throwaway tests, never for a real private AIBrix upstream.
AWS_FULL_GATEWAY_SCHEME=internal
AWS_FULL_GATEWAY_LB_TYPE=external

# Cognito bootstrap test users.
# You MUST set a non-default password in .aws-danger.env. The scripts reject the placeholder.
COGNITO_TEST_PASSWORD=
TENANT_A_USERNAME=tenant-a-alice
TENANT_B_USERNAME=tenant-b-bob

# S3 bucket prefix. The script appends account, region, and cluster name for uniqueness.
ARTIFACT_BUCKET_PREFIX=aibrix-llm-artifacts

# Default model cache is emptyDir, so pods re-download on reschedule. Set efs_pvc only after creating a PVC.
MODEL_CACHE_VOLUME_MODE=emptyDir
MODEL_CACHE_PVC_NAME=

# NVIDIA device plugin install is treated as critical by default.
# Set SKIP_NVIDIA_DEVICE_PLUGIN=true only if your node AMI/add-on already provides nvidia.com/gpu.
SKIP_NVIDIA_DEVICE_PLUGIN=false

# AWS Load Balancer Controller. The full-stack gateway deploy now requires this to be installed.
AWS_LOAD_BALANCER_CONTROLLER_VERSION=1.8.4
AWS_LBC_POLICY_NAME=AWSLoadBalancerControllerIAMPolicy-${CLUSTER_NAME}

# Distributed quota backend. Full-stack deployment refuses in-memory quota.
REDIS_NODE_TYPE=cache.t4g.micro
REDIS_ENGINE_VERSION=7.1
REDIS_PORT=6379
# scripts/aws-danger/09-create-redis-quota-backend.sh writes APP_REDIS_QUOTA_URL to .aws-danger-redis.env.
APP_QUOTA_MODE=redis

# AWS-native reference billing ledger. Optional, but required if APP_BILLING_MODE=aws_native_reference.
BILLING_OBJECT_LOCK_DAYS=30
# scripts/aws-danger/11-create-aws-native-billing-ledger.sh writes APP_AWS_BILLING_S3_BUCKET.
APP_BILLING_MODE=observability
APP_AWS_BILLING_DYNAMODB_TABLE=

# OIDC hardening defaults for the gateway runtime.
APP_OIDC_REQUIRED_TOKEN_USE=id
APP_OIDC_LEEWAY_SECONDS=60
APP_JWKS_CACHE_TTL_SECONDS=300

# Pod Identity/IRSA for gateway AWS API calls. Populated by aws-danger-pod-identity.
GATEWAY_IRSA_ROLE_ARN=

# Standard Kubernetes NetworkPolicy cannot do FQDN egress. The lab keeps HTTPS open
# for Cognito/JWKS through NAT by default. In stricter clusters, replace this with
# Cilium/Calico FQDN policy or private AWS endpoint routing.
AWS_FULL_OPTIONAL_PUBLIC_HTTPS_EGRESS_CIDR=0.0.0.0/0
